{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/renders/layout,_N_T_/renders/page,_N_T_/renders"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/renders/__PAGE__",
    "/renders",
    "/_index",
    "/_head"
  ]
}