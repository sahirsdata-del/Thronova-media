{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/settings/layout,_N_T_/settings/storage/layout,_N_T_/settings/storage/page,_N_T_/settings/storage"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/settings/storage/__PAGE__",
    "/settings/storage",
    "/settings",
    "/_index",
    "/_head"
  ]
}