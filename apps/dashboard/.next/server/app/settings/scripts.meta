{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/settings/layout,_N_T_/settings/scripts/layout,_N_T_/settings/scripts/page,_N_T_/settings/scripts"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/settings/scripts/__PAGE__",
    "/settings/scripts",
    "/settings",
    "/_index",
    "/_head"
  ]
}