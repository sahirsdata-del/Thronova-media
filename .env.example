# ==============================================================================
# THRONOVA MEDIA - PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# This is an example .env file containing all configuration parameters 
# required for a production deployment. Duplicate this file as '.env' 
# and replace placeholders with actual secure values.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# Primary Postgres database connection string. Used by Prisma client.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/thronova_production"

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
# Redis connection parameters for BullMQ task queues.
# Use REDIS_URL for full connection string or individual variables.
REDIS_URL="redis://user:password@localhost:6379/0"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD="your_secure_redis_password_here"

# ------------------------------------------------------------------------------
# AI
# ------------------------------------------------------------------------------
# API keys for generative AI and LLM models.
GEMINI_API_KEY="AIzaSy..._your_google_gemini_api_key_here"
OPENAI_API_KEY="sk-..._your_openai_api_key_here"

# ------------------------------------------------------------------------------
# STORAGE
# ------------------------------------------------------------------------------
# Root directory for storing temporary assets, renders, and media files.
# For production docker setups, this should point to a persistent mounted volume.
STORAGE_ROOT="/opt/thronova-media/storage"
# Google Drive integration for asset archiving
GOOGLE_DRIVE_CLIENT_ID="your_google_drive_client_id.apps.googleusercontent.com"
GOOGLE_DRIVE_CLIENT_SECRET="your_google_drive_client_secret"

# ------------------------------------------------------------------------------
# RENDERING
# ------------------------------------------------------------------------------
# Configurations for the Remotion Render Worker.
# Pexels API used for fetching stock background video/images during rendering.
PEXELS_API_KEY="your_pexels_api_key_here"
# Maximum concurrent browser instances Remotion is allowed to spawn.
REMOTION_CONCURRENCY="4"
# Maximum timeout for a render job (in milliseconds).
RENDER_TIMEOUT_MS="300000"

# ------------------------------------------------------------------------------
# YOUTUBE
# ------------------------------------------------------------------------------
# Google Cloud Platform credentials with YouTube Data API v3 enabled.
YOUTUBE_CLIENT_ID="your_youtube_client_id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="your_youtube_client_secret"
YOUTUBE_REFRESH_TOKEN="1//your_long_lived_refresh_token"
YOUTUBE_REDIRECT_URL="https://your-production-domain.com/api/auth/youtube/callback"

# ------------------------------------------------------------------------------
# META
# ------------------------------------------------------------------------------
# Meta Developer Portal credentials for Instagram/Facebook publishing.
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_PAGE_ACCESS_TOKEN="your_long_lived_page_access_token"

# ------------------------------------------------------------------------------
# ANALYTICS
# ------------------------------------------------------------------------------
# API endpoints and keys for ingestion telemetry/analytics.
POSTHOG_API_KEY="phc_your_posthog_api_key"
POSTHOG_HOST="https://app.posthog.com"
# Optional Google Analytics integration.
GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ------------------------------------------------------------------------------
# AUTHENTICATION
# ------------------------------------------------------------------------------
# NextAuth configuration for Dashboard access.
NEXTAUTH_URL="https://your-production-domain.com"
# Generate a secret via: `openssl rand -base64 32`
NEXTAUTH_SECRET="your_generated_nextauth_secret_here"
# Secure endpoint validation for internal CRON invocations.
CRON_SECRET="your_secure_cron_trigger_secret_here"

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
# Enable or disable beta features globally. (true/false)
ENABLE_EXPERIMENTAL_RENDERS="false"
ENABLE_AUTO_PUBLISH="true"
ENABLE_DRAFT_APPROVAL_FLOW="false"

# ------------------------------------------------------------------------------
# MONITORING
# ------------------------------------------------------------------------------
# Sentry DSN for error tracking and APM.
SENTRY_DSN="https://your_sentry_dsn_here@o0.ingest.sentry.io/0"
# Application environment (development | staging | production).
NODE_ENV="production"
# Server logging verbosity (debug | info | warn | error).
LOG_LEVEL="info"
# Dashboard base HTTP port (Workers dynamically pick their health ports if empty).
PORT="3000"
