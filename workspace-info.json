  "apps/dashboard": {
    "packageJson": {
      "name": "thronova-dashboard",
      "version": "0.1.0",
      "private": true,
      "scripts": {
        "dev": "next dev",
        "build": "DATABASE_URL=postgresql://mock:mock@localhost/mock next build",
        "start": "next start",
        "lint": "eslint"
      },
      "dependencies": {
        "@auth/prisma-adapter": "^2.11.2",
        "@base-ui/react": "^1.6.0",
        "@prisma/client": "^7.8.0",
        "@remotion/bundler": "^4.0.489",
        "@remotion/renderer": "^4.0.489",
        "@remotion/zod-types": "^4.0.489",
        "@tanstack/react-query": "^5.101.2",
