{
  "name": "thronova-media-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "workers/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "tsc -b && npm run build --workspace=thronova-dashboard",
    "start": "npm run start --workspaces --if-present"
  },
  "overrides": {
    "ioredis": "^5.11.1"
  }
}
